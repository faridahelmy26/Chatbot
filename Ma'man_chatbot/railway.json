{
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cd Ma'man_chatbot && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd Ma'man_chatbot && uvicorn app.api:app --host 0.0.0.0 --port ${PORT:-8000} --timeout-keep-alive 120",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}
